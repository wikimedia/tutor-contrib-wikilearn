# WikiLearn: apply the Learner Credential Wallet (LCW) compatibility fixes.
#
# tutor-credentials v20 builds the Credentials image from CREDENTIALS_REPOSITORY_VERSION
# (release/teak.3 for WikiLearn). That tag predates three fixes that were later
# backported to the openedx/credentials release/teak branch. Without them,
# verifiable credentials get stuck at the "credential storage" step or show as
# "revoked by issuer" in recent LC Wallet versions (>= 2.1.5).
#
# This is the Teak path recommended by the credentials maintainer: apply the three
# commits via this dockerfile hook (the Ulmo path is simply bumping the plugin).
# https://discuss.openedx.org/t/verifiable-credentials-qr-code-scan-issue-stuck-at-credential-storage-step/18349/12
RUN cd /openedx/credentials && \
    git config user.email "tutor@wikilearn" && \
    git config user.name "WikiLearn" && \
    curl -fsSL https://github.com/openedx/credentials/commit/1b2beadb3bbb2e3004c0b88c902c6f0b1b87d5e7.patch | git am && \
    curl -fsSL https://github.com/openedx/credentials/commit/c28a7459e1dd1366738be96a4635115b945dda0f.patch | git am && \
    curl -fsSL https://github.com/openedx/credentials/commit/f084e2dfbe76351a67749bcffdf0bf134b2df397.patch | git am
